{
  "name": "obs-tiktoklivestudio",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffold for OBS + TikTok Live Studio workflows with linked scene/source and Stream Deck organization",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @obs-tiktok/web",
    "dev:plugin": "npm run dev --workspace @obs-tiktok/streamdeck-plugin",
    "build": "npm run build --workspace @obs-tiktok/web && npm run build --workspace @obs-tiktok/streamdeck-plugin",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:file": "vitest run --reporter=verbose",
    "test:incremental": "vitest run --changed --bail",
    "test:strict": "vitest run --bail",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
